{
  "name": "pagevoice",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "PageVoice turns readable web content into narrated audio from a browser extension.",
  "scripts": {
    "dev": "vite --config vite.config.ts",
    "test": "vitest run",
    "build": "npm run build:chromium",
    "build:chromium": "tsx scripts/buildChromium.ts",
    "build:firefox": "tsx scripts/buildFirefox.ts",
    "build:safari-prep": "tsx scripts/buildSafariPrep.ts",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build:chromium && npm run build:firefox && npm run build:safari-prep",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "lucide-react": "^1.18.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/chrome": "^0.1.43",
    "@types/node": "^25.9.3",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^6.1.0",
    "vitest": "^3.0.5"
  }
}
